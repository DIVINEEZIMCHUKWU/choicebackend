{
  "version": 2,
  "buildCommand": "npm install --prefix api",
  "env": {
    "SUPABASE_URL": "@supabase_url",
    "SUPABASE_KEY": "@supabase_key",
    "SENDGRID_API_KEY": "@sendgrid_api_key",
    "SENDGRID_FROM_EMAIL": "@sendgrid_from_email"
  },
  "functions": {
    "api/server.mjs": {
      "runtime": "nodejs18.x",
      "memory": 1024,
      "maxDuration": 60
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/server.mjs"
    },
    {
      "src": "/(.*)",
      "status": 404
    }
  ]
}
